# but for this repo's own demo we regenerate it, so keep it out of git:
pragmasearch-index.json

# large 10k test artifacts — reproducible via `npm run fetch:10k && npm run index:10k`
pragmasearch-index-10k.json
data/products-10k.json
demo/.server*.log

# it-shop.rs raw feed + products stay private (the deployed server only needs the index)
data/eponuda.xml
data/products-itshop.json
data/.index-itshop.log
# NOTE: pragmasearch-index-itshop.json IS committed (the server-side demo deploy needs it).
