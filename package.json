{
  "name": "pragmasearch",
  "version": "0.5.0",
  "description": "Open-source local-first semantic search engine. Drop in a products JSON, get hybrid (keyword + meaning) search with zero cloud, zero API keys, $0.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "search",
    "semantic-search",
    "vector-search",
    "embeddings",
    "transformers.js",
    "local-first",
    "algolia-alternative",
    "hybrid-search",
    "e-commerce",
    "react"
  ],
  "bin": {
    "pragmasearch": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./widget/*": "./widget/*"
  },
  "files": [
    "dist",
    "widget"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/engine.test.ts test/analytics.test.ts test/react-core.test.ts test/react.test.tsx",
    "index": "tsx src/cli.ts index",
    "search": "tsx src/cli.ts search",
    "demo": "tsx demo/server.ts",
    "demo:index": "tsx src/cli.ts index data/products.json",
    "sample": "tsx scripts/make-sample.ts",
    "example": "tsx examples/quickstart.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
